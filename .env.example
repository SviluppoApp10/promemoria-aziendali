# ============================================================
# PROMEMORIA AZIENDALI — Configurazione ambiente
# Copia questo file in .env e compila i valori
# ============================================================

# Database PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=promemoria_db
DB_USER=postgres
DB_PASSWORD=StrongPassword123!

# JWT
JWT_SECRET=cambia_con_una_chiave_segreta_di_almeno_64_caratteri_random
JWT_EXPIRES=8h

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# SMTP (email) — es. Gmail, Outlook, SMTP aziendale
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tua.email@gmail.com
SMTP_PASS=tua_app_password
SMTP_FROM_NAME=Promemoria Aziendali
SMTP_FROM_EMAIL=tua.email@gmail.com

# Log
LOG_LEVEL=info
LOG_DIR=logs
